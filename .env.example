# Copy this file to .env.local and fill in real values for local development.
# Schema and validation: config/env.ts

# --- Server-only (never prefix with NEXT_PUBLIC_) ---

# GitHub personal access token, used by lib/github for higher rate limits
# and access to private data. Optional in development.
GITHUB_TOKEN=

# --- Public (exposed to the client bundle) ---

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=charan-os
NEXT_PUBLIC_SITE_DESCRIPTION="Personal website, digital headquarters, and living knowledge platform."

# GitHub username to source repos/profile data from.
NEXT_PUBLIC_GITHUB_USERNAME=
