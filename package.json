{
  "name": "charan-os",
  "version": "0.1.0",
  "private": true,
  "description": "Personal website, digital headquarters, and living knowledge platform — engineering foundation.",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "prepare": "husky"
  },
  "dependencies": {
    "@content-collections/core": "0.15.2",
    "@content-collections/mdx": "0.2.2",
    "@content-collections/next": "0.2.11",
    "@octokit/rest": "22.0.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@vercel/analytics": "2.0.1",
    "@xyflow/react": "12.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "feed": "6.0.0",
    "framer-motion": "12.42.2",
    "lucide-react": "1.25.0",
    "mermaid": "11.16.0",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-autolink-headings": "7.1.0",
    "rehype-pretty-code": "0.14.4",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "sharp": "0.35.3",
    "shiki": "4.3.1",
    "tailwind-merge": "3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@tailwindcss/typography": "0.5.20",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "tailwindcss": "4.3.3",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{js,jsx,ts,tsx,md,mdx,json,css}": [
      "prettier --write"
    ]
  }
}
